#!/usr/bin/env bash

# Release Script
# Automates the build, tagging, and releasing process to GitHub and GitLab.

set -e # Exit immediately if a command exits with a non-zero status.

VERSION="$1"

if [[ -z "$VERSION" ]]; then
    echo -e "\033[1;31m❌ Error:\033[0m Missing version argument."
    echo -e "\033[1;33mUsage:\033[0m ./scripts/release <vX.Y.Z>"
    exit 1
fi

echo -e "🚀 \033[1;34mStarting Release Pipeline for $VERSION\033[0m..."

# 1. Clean and Deploy (Build artifacts)
echo -e "\n🧹 \033[1;36mRunning clean and deploy...\033[0m"
./scripts/clean
./scripts/deploy

# 2. Archive to tmp/ directory
echo -e "\n📦 \033[1;36mCreating archive in tmp/...\033[0m"
mkdir -p tmp
TAR_FILE="tmp/bash-lib-modules.tar.gz"
tar -czvf "$TAR_FILE" lib/

# 3. Git Commit & Tag
echo -e "\n🏷️ \033[1;36mCommitting and Tagging...\033[0m"
git add .
# Prevent script failure if there are no new changes to commit
git commit -m "chore(release): bump to $VERSION" || echo -e "\033[1;33mNo new changes to commit.\033[0m"
git tag "$VERSION"

# 4. Push to remotes
echo -e "\n☁️ \033[1;36mPushing to remotes...\033[0m"
# Push main branch explicitly to ensure remotes are synced
git push origin main
git push origin "$VERSION"
git push gitlab main
git push gitlab "$VERSION"

# 5. Create GitHub & GitLab Releases
echo -e "\n🎉 \033[1;36mPublishing Releases...\033[0m"
NOTES="Automated stable release generated by deploy script for $VERSION."

gh release create "$VERSION" --title "Release $VERSION" --notes "$NOTES" bash-lib "$TAR_FILE"
glab release create "$VERSION" --name "Release $VERSION" --notes "$NOTES" bash-lib "$TAR_FILE"

# 6. Cleanup
echo -e "\n🧹 \033[1;36mCleaning up temporary files...\033[0m"
rm -f "$TAR_FILE"

echo -e "\n✅ \033[1;32mSuccessfully released $VERSION to GitHub and GitLab!\033[0m"
